# 환경 변수 템플릿 - 이 파일을 .env로 복사 후 값 입력
# cp .env.example .env

# ----- 데이터베이스 (MySQL) -----
# 형식: mysql+aiomysql://user:password@host:port/dbname
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/heimdall

# ----- Redis (리프레시 토큰, 액세스 토큰 블랙리스트) -----
REDIS_URL=redis://localhost:6379/0

# ----- Auth (JWT) -----
JWT_SECRET_KEY=change-me-in-production

# ----- Google OAuth -----
# 필수. 구글 클라우드 콘솔에서 발급 (OAuth 2.0 클라이언트 ID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ----- CORS -----
# 허용할 origin 목록 (쉼표 구분), 미설정 시 http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,https://example.com

# ----- 서버 -----
# DEBUG=true
# APP_ENV=development

# ----- 이미지 업로드 -----
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:8000
